#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/docker-phase1 build
  bin/docker-phase1 check
  bin/docker-phase1 up
  bin/docker-phase1 all

Commands:
  build  Build the Ubuntu 18.04 / Ruby 2 app image.
  check  Print Ruby version and verify Rails boots.
  up     Start the Rails app with docker compose.
  all    Run build, check, then up.
USAGE
}

cmd="${1:-}"

case "$cmd" in
  build)
    docker compose build app
    ;;
  check)
    docker compose run --rm app ruby -v
    docker compose run --rm app bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  up)
    docker compose up app
    ;;
  all)
    "$0" build
    "$0" check
    "$0" up
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

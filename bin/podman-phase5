#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/podman-phase5 ubuntu26-build
  bin/podman-phase5 ubuntu26-check
  bin/podman-phase5 ubuntu26-yjit-check
  bin/podman-phase5 ubuntu26-test
  bin/podman-phase5 ubuntu26-assets
  bin/podman-phase5 ubuntu26-up
  bin/podman-phase5 ubuntu26-stack
  bin/podman-phase5 ubuntu26-security
  bin/podman-phase5 ubuntu26-system-test

Commands:
  ubuntu26-build       Build the Ubuntu 26.04 / Ruby 4.0 app image.
  ubuntu26-check       Print Ruby version and verify Rails boots on Ubuntu 26.04.
  ubuntu26-yjit-check  Confirm YJIT is compiled in and enabled by Rails on Ubuntu 26.04.
  ubuntu26-test        Run the Rails test suite on Ubuntu 26.04.
  ubuntu26-assets      Precompile assets on Ubuntu 26.04.
  ubuntu26-up          Start the Ubuntu 26.04 / Ruby 4.0 Rails app on http://localhost:3008/.
  ubuntu26-stack       Start the Phase 5 app, proxy, worker, and scheduler services.
  ubuntu26-security    Run Brakeman and bundler-audit security checks on Ubuntu 26.04.
  ubuntu26-system-test Drive the running Phase 5 dev stack with headless Chromium via Selenium.
USAGE
}

check_podman() {
  if ! command -v podman > /dev/null 2>&1; then
    echo "ERROR: podman not found. Install podman >= 4.4." >&2
    exit 1
  fi
  if ! podman compose version > /dev/null 2>&1; then
    echo "ERROR: 'podman compose' not available. Install podman >= 4.4 or podman-compose." >&2
    exit 1
  fi
}

# Use podman-compose over docker-compose when both are available.
# docker-compose V2 re-tags images during 'run' in a way that breaks Podman's
# Docker compat API. podman-compose talks to Podman natively and avoids this.
if command -v podman-compose > /dev/null 2>&1; then
  export PODMAN_COMPOSE_PROVIDER
  PODMAN_COMPOSE_PROVIDER="$(command -v podman-compose)"
fi

cmd="${1:-}"

case "$cmd" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
esac

check_podman

case "$cmd" in
  ubuntu26-build)
    # --format docker: Podman's default OCI format silently ignores SHELL;
    # Docker format honors it. ARM64 OCI cached layers have different cache keys
    # and are not reused, so --no-cache is not needed.
    podman build \
      --platform linux/amd64 \
      --format docker \
      -t joruri-mail:phase5-ubuntu26-ruby4 \
      -f docker/ubuntu26-ruby4/Dockerfile \
      .
    ;;
  ubuntu26-check)
    podman compose run --rm app-ubuntu26-ruby4 ruby -v
    podman compose run --rm app-ubuntu26-ruby4 bundle exec rails runner 'abort "YJIT is not enabled" unless defined?(RubyVM::YJIT) && RubyVM::YJIT.enabled?; puts "Ruby #{RUBY_VERSION} Rails #{Rails.version} booted with YJIT"'
    ;;
  ubuntu26-yjit-check)
    podman compose run --rm --no-deps app-ubuntu26-ruby4 bundle exec rails runner \
      'puts "YJIT enabled: #{RubyVM::YJIT.enabled?}"'
    ;;
  ubuntu26-test)
    podman compose run --rm app-ubuntu26-ruby4 bundle exec rails test
    ;;
  ubuntu26-assets)
    podman compose run --rm -u joruri app-ubuntu26-ruby4 bundle exec rake assets:precompile
    ;;
  ubuntu26-up)
    podman compose up app-ubuntu26-ruby4
    ;;
  ubuntu26-stack)
    podman compose up app-ubuntu26-ruby4-proxy app-ubuntu26-ruby4-worker app-ubuntu26-ruby4-scheduler
    ;;
  ubuntu26-security)
    podman compose run --rm --no-deps app-ubuntu26-ruby4 bundle exec brakeman -q --no-exit-on-warn
    podman compose run --rm --no-deps app-ubuntu26-ruby4 bundle exec bundler-audit check --update
    ;;
  ubuntu26-system-test)
    podman compose up -d app-ubuntu26-ruby4 app-ubuntu26-ruby4-selenium
    podman compose run --rm \
      -e RAILS_ENV=development \
      -e CAPYBARA_APP_HOST=http://app-ubuntu26-ruby4:3000 \
      -e SELENIUM_REMOTE_URL=http://app-ubuntu26-ruby4-selenium:4444/wd/hub \
      -e SYSTEM_TEST_HOSTS=app-ubuntu26-ruby4 \
      app-ubuntu26-ruby4 \
      bundle exec rails test test/system
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

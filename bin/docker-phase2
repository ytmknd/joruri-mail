#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/docker-phase2 build
  bin/docker-phase2 check
  bin/docker-phase2 up
  bin/docker-phase2 ruby25-build
  bin/docker-phase2 ruby25-check
  bin/docker-phase2 ruby25-up
  bin/docker-phase2 bundle-update-rails50
  bin/docker-phase2 bundle-update-rails51
  bin/docker-phase2 bundle-update-rails52
  bin/docker-phase2 all

Commands:
  build                 Build the Ubuntu 18.04 / Ruby 2.3 app image for Rails 5 migration.
  check                 Print Ruby version and verify Rails boots.
  up                    Start the phase 2 Rails app on http://localhost:3001/.
  ruby25-build          Build the Ubuntu 18.04 / Ruby 2.5 app image.
  ruby25-check          Print Ruby version and verify Rails boots on Ruby 2.5.
  ruby25-up             Start the Ruby 2.5 Rails app on http://localhost:3002/.
  bundle-update-rails50 Update Rails to the latest allowed Rails 5.0.x patch in Gemfile.lock.
  bundle-update-rails51 Update Rails and known Rails 5.1 blockers in the Ruby 2.5 service.
  bundle-update-rails52 Update Rails and known Rails 5.2 blockers in the Ruby 2.5 service.
  all                   Run build, check, then up.
USAGE
}

cmd="${1:-}"

case "$cmd" in
  build)
    docker compose build app-phase2
    ;;
  check)
    docker compose run --rm app-phase2 ruby -v
    docker compose run --rm app-phase2 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  up)
    docker compose up app-phase2
    ;;
  ruby25-build)
    docker compose --profile ruby-upgrade build app-ruby25
    ;;
  ruby25-check)
    docker compose --profile ruby-upgrade run --rm app-ruby25 ruby -v
    docker compose --profile ruby-upgrade run --rm app-ruby25 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  ruby25-up)
    docker compose --profile ruby-upgrade up app-ruby25
    ;;
  bundle-update-rails50)
    docker compose run --rm app-phase2 bundle update rails --conservative
    ;;
  bundle-update-rails51)
    docker compose --profile ruby-upgrade run --rm --user 1000:1000 --entrypoint bundle app-ruby25 _1.17.3_ update rails activerecord-session_store jbuilder
    ;;
  bundle-update-rails52)
    docker compose --profile ruby-upgrade run --rm --user 1000:1000 --entrypoint bundle app-ruby25 _1.17.3_ update rails coffee-rails
    ;;
  all)
    "$0" build
    "$0" check
    "$0" up
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

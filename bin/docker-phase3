#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/docker-phase3 ubuntu20-build
  bin/docker-phase3 ubuntu20-check
  bin/docker-phase3 ubuntu20-up
  bin/docker-phase3 ubuntu20-proxy-up
  bin/docker-phase3 ubuntu20-worker-up
  bin/docker-phase3 ubuntu20-scheduler-up
  bin/docker-phase3 ubuntu20-stack-up
  bin/docker-phase3 ubuntu20-stack-check
  bin/docker-phase3 ubuntu20-smoke
  bin/docker-phase3 all

Commands:
  ubuntu20-build  Build the Ubuntu 20.04 / Ruby 2.7 app image.
  ubuntu20-check  Print Ruby version and verify Rails boots on Ubuntu 20.04.
  ubuntu20-up     Start the Ubuntu 20.04 / Ruby 2.7 Rails app on http://localhost:3004/.
  ubuntu20-proxy-up
                  Start the Phase 4 Nginx reverse proxy on http://localhost:3005/.
  ubuntu20-worker-up
                  Start delayed_job as a separate Phase 4 worker process.
  ubuntu20-scheduler-up
                  Start scheduled cleanup as a separate Phase 4 process.
  ubuntu20-stack-up
                  Start the Phase 4 web, proxy, worker, and scheduler stack.
  ubuntu20-stack-check
                  Verify the Phase 4 proxy endpoint responds.
  ubuntu20-smoke  Run non-destructive Phase 3 smoke checks against a running app.
  all             Run ubuntu20-build, ubuntu20-check, then ubuntu20-up.
USAGE
}

cmd="${1:-}"

case "$cmd" in
  ubuntu20-build)
    docker compose --profile phase3 build app-ubuntu20-ruby27
    ;;
  ubuntu20-check)
    docker compose --profile phase3 run --rm app-ubuntu20-ruby27 ruby -v
    docker compose --profile phase3 run --rm app-ubuntu20-ruby27 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  ubuntu20-up)
    docker compose --profile phase3 up app-ubuntu20-ruby27
    ;;
  ubuntu20-proxy-up)
    docker compose --profile phase3 up app-ubuntu20-ruby27-proxy
    ;;
  ubuntu20-worker-up)
    docker compose --profile phase3 up app-ubuntu20-ruby27-worker
    ;;
  ubuntu20-scheduler-up)
    docker compose --profile phase3 up app-ubuntu20-ruby27-scheduler
    ;;
  ubuntu20-stack-up)
    docker compose --profile phase3 up app-ubuntu20-ruby27 app-ubuntu20-ruby27-proxy app-ubuntu20-ruby27-worker app-ubuntu20-ruby27-scheduler
    ;;
  ubuntu20-stack-check)
    curl -fsSI http://localhost:3005/_admin/login
    ;;
  ubuntu20-smoke)
    docker compose --profile phase3 exec app-ubuntu20-ruby27 bundle exec rails runner 'p Webmail::Lib::Server.check_status'
    docker compose --profile phase3 exec app-ubuntu20-ruby27 bundle exec rake webmail:cleanup
    docker compose --profile phase3 exec app-ubuntu20-ruby27 bundle exec rails runner 'Delayed::Job.where(queue: "phase3-smoke").delete_all; "phase3-smoke".delay(queue: "phase3-smoke").length; puts "queued=#{Delayed::Job.where(queue: "phase3-smoke").count}"'
    docker compose --profile phase3 run --rm -e QUEUES=phase3-smoke app-ubuntu20-ruby27-worker bundle exec rake jobs:workoff
    docker compose --profile phase3 exec -T app-ubuntu20-ruby27 ruby <<'RUBY'
require 'net/smtp'
require 'net/imap'
require 'nkf'
require 'securerandom'

id = "phase3-#{SecureRandom.hex(4)}"
subject = "ISO-2022-JP #{id}"
body = NKF.nkf('-Wj', "日本語本文 #{id}").b
head = <<~MAIL.gsub("\n", "\r\n").b
  From: user1
  To: user1
  Subject: #{subject}
  MIME-Version: 1.0
  Content-Type: text/plain; charset=ISO-2022-JP
  Content-Transfer-Encoding: 7bit

MAIL

Net::SMTP.start('imap', 3025, 'localhost.localdomain.jp') do |smtp|
  smtp.send_message(head + body + "\r\n".b, 'user1', 'user1')
end

sleep 1
imap = Net::IMAP.new('imap', 3143)
imap.login('user1', 'user1')
imap.select('INBOX')
uids = imap.uid_search(['SUBJECT', subject], 'UTF-8')
raise 'message not found' if uids.empty?

begin
  imap.create('Phase3Smoke')
rescue Net::IMAP::NoResponseError
end

imap.uid_copy(uids, 'Phase3Smoke')
imap.select('Phase3Smoke')
moved = imap.uid_search(['SUBJECT', subject], 'UTF-8')
raise 'message not copied' if moved.empty?
imap.uid_store(moved, '+FLAGS', [:Deleted])
imap.expunge

imap.select('INBOX')
imap.uid_store(uids, '+FLAGS', [:Deleted])
imap.expunge
imap.logout

puts "smtp_imap_iso2022jp_ok #{id}"
RUBY
    ;;
  all)
    "$0" ubuntu20-build
    "$0" ubuntu20-check
    "$0" ubuntu20-up
    ;;
  ""|-h|--help|help)
    usage
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac

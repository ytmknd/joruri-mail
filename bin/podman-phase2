#!/usr/bin/env bash
set -euo pipefail

usage() {
  cat <<'USAGE'
Usage:
  bin/podman-phase2 build
  bin/podman-phase2 check
  bin/podman-phase2 up
  bin/podman-phase2 ruby25-build
  bin/podman-phase2 ruby25-check
  bin/podman-phase2 ruby25-up
  bin/podman-phase2 ruby27-build
  bin/podman-phase2 ruby27-check
  bin/podman-phase2 ruby27-up
  bin/podman-phase2 bundle-update-rails50
  bin/podman-phase2 bundle-update-rails51
  bin/podman-phase2 bundle-update-rails52
  bin/podman-phase2 all

Commands:
  build                 Build the Ubuntu 18.04 / Ruby 2.3 app image for Rails 5 migration.
  check                 Print Ruby version and verify Rails boots.
  up                    Start the phase 2 Rails app on http://localhost:3001/.
  ruby25-build          Build the Ubuntu 18.04 / Ruby 2.5 app image.
  ruby25-check          Print Ruby version and verify Rails boots on Ruby 2.5.
  ruby25-up             Start the Ruby 2.5 Rails app on http://localhost:3002/.
  ruby27-build          Build the Ubuntu 18.04 / Ruby 2.7 app image.
  ruby27-check          Print Ruby version and verify Rails boots on Ruby 2.7.
  ruby27-up             Start the Ruby 2.7 Rails app on http://localhost:3003/.
  bundle-update-rails50 Update Rails to the latest allowed Rails 5.0.x patch in Gemfile.lock.
  bundle-update-rails51 Update Rails and known Rails 5.1 blockers in the Ruby 2.5 service.
  bundle-update-rails52 Update Rails and known Rails 5.2 blockers in the Ruby 2.5 service.
  all                   Run build, check, then up.
USAGE
}

check_podman() {
  if ! command -v podman > /dev/null 2>&1; then
    echo "ERROR: podman not found. Install podman >= 4.4." >&2
    exit 1
  fi
  if ! podman compose version > /dev/null 2>&1; then
    echo "ERROR: 'podman compose' not available. Install podman >= 4.4 or podman-compose." >&2
    exit 1
  fi
}

# Use podman-compose over docker-compose when both are available.
# docker-compose V2 re-tags images during 'run' in a way that breaks Podman's
# Docker compat API. podman-compose talks to Podman natively and avoids this.
if command -v podman-compose > /dev/null 2>&1; then
  export PODMAN_COMPOSE_PROVIDER
  PODMAN_COMPOSE_PROVIDER="$(command -v podman-compose)"
fi

cmd="${1:-}"

case "$cmd" in
  ""|-h|--help|help)
    usage
    exit 0
    ;;
esac

check_podman

case "$cmd" in
  build)
    podman compose build app-phase2
    ;;
  check)
    podman compose run --rm app-phase2 ruby -v
    podman compose run --rm app-phase2 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  up)
    podman compose up app-phase2
    ;;
  ruby25-build)
    podman compose --profile ruby-upgrade build app-ruby25
    ;;
  ruby25-check)
    podman compose --profile ruby-upgrade run --rm app-ruby25 ruby -v
    podman compose --profile ruby-upgrade run --rm app-ruby25 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  ruby25-up)
    podman compose --profile ruby-upgrade up app-ruby25
    ;;
  ruby27-build)
    podman compose --profile ruby-upgrade build app-ruby27
    ;;
  ruby27-check)
    podman compose --profile ruby-upgrade run --rm app-ruby27 ruby -v
    podman compose --profile ruby-upgrade run --rm app-ruby27 bundle exec rails runner 'puts "Rails #{Rails.version} booted"'
    ;;
  ruby27-up)
    podman compose --profile ruby-upgrade up app-ruby27
    ;;
  bundle-update-rails50)
    podman compose run --rm app-phase2 bundle update rails --conservative
    ;;
  bundle-update-rails51)
    podman compose --profile ruby-upgrade run --rm --user 1000:1000 --entrypoint bundle app-ruby25 _1.17.3_ update rails activerecord-session_store jbuilder
    ;;
  bundle-update-rails52)
    podman compose --profile ruby-upgrade run --rm --user 1000:1000 --entrypoint bundle app-ruby25 _1.17.3_ update rails coffee-rails
    ;;
  all)
    "$0" build
    "$0" check
    "$0" up
    ;;
  *)
    usage >&2
    exit 2
    ;;
esac
